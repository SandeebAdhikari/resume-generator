# AI provider: ollama (local, default) or openai
AI_PROVIDER=ollama

# Native Ollama (recommended on Mac) — open the Ollama app from Applications
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Docker Ollama (optional, kept in repo): from repo root run ./scripts/ollama-docker.sh
# Stop native Ollama first — both use port 11434

# Optional tuning
# OLLAMA_NUM_CTX=8192
# OLLAMA_NUM_PREDICT=6000
# OLLAMA_TIMEOUT_MS=600000

# OpenAI settings (only needed when AI_PROVIDER=openai)
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=gpt-4.1-mini

PORT=8787
